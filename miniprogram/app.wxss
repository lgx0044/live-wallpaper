/* app.wxss — 全局样式 */

/* CSS 变量 */
page {
  --primary: #6c63ff;
  --primary-light: #8b83ff;
  --bg-dark: #0f0f23;
  --bg-card: #1a1a2e;
  --bg-card2: #25253f;
  --text-primary: #e8e8f0;
  --text-secondary: #9999b3;
  --text-muted: #666680;
  --success: #4ade80;
  --error: #f87171;
  --warning: #fbbf24;
  --radius: 12px;
  --radius-lg: 20px;

  background-color: var(--bg-dark);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* 通用按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: var(--radius);
  color: white;
  font-size: 16px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 48px;
  background: var(--bg-card2);
  border-radius: var(--radius);
  color: var(--text-primary);
  font-size: 16px;
  font-weight: 500;
  border: 1px solid #3a3a5c;
}

.btn-secondary:active {
  opacity: 0.8;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20px;
  margin-bottom: 16px;
}

/* 标题 */
.title {
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 14px;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 24px;
  line-height: 1.5;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding: 24px 20px;
  box-sizing: border-box;
}

/* 错误文字 */
.error-text {
  color: var(--error);
  font-size: 13px;
  text-align: center;
  margin: 8px 0;
}

/* loading 动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
