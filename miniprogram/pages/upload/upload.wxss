/* pages/upload/upload.wxss */

.upload-page {
  display: flex;
  flex-direction: column;
}

/* 插件状态 */
.plugin-status {
  text-align: center;
  margin-bottom: 8px;
}

.plugin-badge {
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 10px;
}

.badge-active {
  background: rgba(52, 211, 153, 0.15);
  color: #34d399;
}

.badge-fallback {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
}

/* 选择区域 */
.picker-area {
  width: 100%;
  min-height: 240px;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2px dashed #3a3a5c;
  margin-bottom: 8px;
  overflow: hidden;
}

.picker-area:active {
  border-color: var(--primary);
}

.picker-empty {
  min-height: 240px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.picker-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.picker-hint {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.picker-subhint {
  font-size: 13px;
  color: var(--text-muted);
  text-align: center;
  padding: 0 32px;
  line-height: 1.5;
}

/* 预览区 */
.picker-preview {
  position: relative;
}

.preview-video {
  width: 100%;
  height: 280px;
  display: block;
}

/* 参数选择 */
.config-section {
  width: 100%;
  margin-bottom: 8px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12px;
  display: block;
}

.preset-list {
  display: flex;
  gap: 10px;
}

.preset-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 14px 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2px solid transparent;
  transition: border-color 0.2s;
}

.preset-item:active {
  opacity: 0.8;
}

.preset-active {
  border-color: var(--primary);
  background: rgba(108, 99, 255, 0.1);
}

.preset-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 2px;
}

.preset-desc {
  font-size: 11px;
  color: var(--text-muted);
  text-align: center;
}

/* 操作区 */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 12px;
}
