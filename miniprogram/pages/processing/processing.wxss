/* pages/processing/processing.wxss */

.processing-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60px;
}

/* 状态区域 */
.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 40px;
}

/* 旋转动画 */
.spinner-ring {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 4px solid var(--bg-card2);
  border-top-color: var(--primary);
  animation: spin 0.8s linear infinite;
  margin-bottom: 24px;
}

.spinner-circle {
  width: 100%;
  height: 100%;
}

/* 失败图标 */
.status-icon {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  font-weight: bold;
  margin-bottom: 16px;
}

.status-fail {
  background: rgba(248, 113, 113, 0.15);
  color: var(--error);
}

.status-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.status-desc {
  font-size: 14px;
  color: var(--text-secondary);
  text-align: center;
  padding: 0 32px;
  line-height: 1.5;
  margin-bottom: 24px;
}

.retry-btn {
  width: 200px;
  margin: 0 auto;
}

/* 进度条 */
.progress-bar {
  width: 200px;
  height: 4px;
  background: var(--bg-card2);
  border-radius: 4px;
  overflow: hidden;
  margin-top: 4px;
  margin-bottom: 12px;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 4px;
  transition: width 0.5s ease;
}

/* 已用时间 */
.elapsed-time {
  font-size: 13px;
  color: var(--text-muted);
}

/* 提示 */
.tips-area {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  flex-direction: column;
}

.tips-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.tips-text {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
}
